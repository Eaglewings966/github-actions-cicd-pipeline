{
  "name": "emmanuel-cicd-app",
  "version": "1.0.0",
  "description": "Sample Node.js application for CI/CD pipeline demonstration",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "devops",
    "cicd",
    "aws",
    "docker",
    "nodejs"
  ],
  "author": "Emmanuel Ubani",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.42.0",
    "prettier": "^2.8.8",
    "nodemon": "^2.0.22"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**"
    ]
  }
}
